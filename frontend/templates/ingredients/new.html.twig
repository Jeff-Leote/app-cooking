{% extends 'layouts/app.html.twig' %}

{% block page_title %}Créer un ingrédient{% endblock %}

{% block content %}
    <div class="space-y-6">
        <div class="bg-white rounded-xl shadow-sm p-8">
            <h2 class="text-2xl font-bold text-dark-blue mb-6">Créer un ingrédient</h2>
            {# Formulaire #}
            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
            
                <div>
                    {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-semibold text-dark-blue mb-2'}}) }}
                    {{ form_widget(form.nom) }}
                    {{ form_errors(form.nom) }}
                </div>
                
                {# Catégorie alimentaire #}
                <div class="pt-4 border-t border-gray-200">
                    <h3 class="text-lg font-semibold text-dark-blue mb-4">Catégorie alimentaire</h3>
                    <div>
                        {{ form_label(form.categorie, null, {'label_attr': {'class': 'block text-sm font-semibold text-dark-blue mb-2'}}) }}
                        {{ form_widget(form.categorie) }}
                        {{ form_errors(form.categorie) }}
                    </div>
                </div>
                
                <div class="pt-4">
                    {{ form_widget(form.submit) }}
                </div>
            
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
