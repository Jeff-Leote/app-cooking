{% extends 'layouts/app.html.twig' %}

{% block page_title %}Créer une recette{% endblock %}

{% block content %}
    <div class="space-y-6">
        <div class="bg-white rounded-xl shadow-sm p-8">
            <h2 class="text-2xl font-bold text-dark-blue mb-6">Créer une recette</h2>
            
            {{ form_start(form, {'attr': {'class': 'space-y-6', 'id': 'recipe-form'}}) }}
            
                <div>
                    {{ form_label(form.titre, null, {'label_attr': {'class': 'block text-sm font-semibold text-dark-blue mb-2'}}) }}
                    {{ form_widget(form.titre) }}
                    {{ form_errors(form.titre) }}
                </div>
                
                <div>
                    {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-semibold text-dark-blue mb-2'}}) }}
                    {{ form_widget(form.description, {'attr': {'rows': 8, 'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-green focus:border-transparent resize-none'}}) }}
                    {{ form_errors(form.description) }}
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        {{ form_label(form.temps_preparation, null, {'label_attr': {'class': 'block text-sm font-semibold text-dark-blue mb-2'}}) }}
                        {{ form_widget(form.temps_preparation) }}
                        {{ form_errors(form.temps_preparation) }}
                    </div>
                    <div>
                        {{ form_label(form.image_url, null, {'label_attr': {'class': 'block text-sm font-semibold text-dark-blue mb-2'}}) }}
                        {{ form_widget(form.image_url) }}
                        {{ form_errors(form.image_url) }}
                    </div>
                </div>
                
                <div class="flex items-center">
                    {{ form_widget(form.is_favorite) }}
                    {{ form_label(form.is_favorite, null, {'label_attr': {'class': 'ml-2 text-sm font-semibold text-dark-blue'}}) }}
                    {{ form_errors(form.is_favorite) }}
                </div>
                
                <div class="pt-6 border-t border-gray-200">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-semibold text-dark-blue">Ingrédients</h3>
                        <button type="button" id="add-ingredient-btn" class="inline-flex items-center gap-2 bg-primary-green text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-primary-green/90 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                            </svg>
                            Ajouter un ingrédient
                        </button>
                    </div>
                    
                    <div id="ingredients-list" class="space-y-3"></div>
                    <div id="ingredient-prototype" data-prototype="{{ form_widget(form.ingredients.vars.prototype)|e('html_attr') }}" style="display: none;"></div>
                    {{ form_errors(form.ingredients) }}
                </div>
                
                <div class="pt-4">
                    {{ form_widget(form.submit) }}
                </div>
            
            {{ form_end(form) }}
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const addBtn = document.getElementById('add-ingredient-btn');
            const ingredientsList = document.getElementById('ingredients-list');
            const prototype = document.getElementById('ingredient-prototype');
            let index = 0;
            
            function addIngredient() {
                if (!prototype || !prototype.dataset.prototype) return;
                
                const html = prototype.dataset.prototype.replace(/__name__/g, index);
                const div = document.createElement('div');
                div.className = 'ingredient-item bg-gray-50 p-4 rounded-lg border border-gray-200';
                div.innerHTML = '<div class="space-y-4">' + html + '</div>';
                
                // Trouver le champ quantité (chercher de plusieurs façons)
                const qtyInput = div.querySelector('input[name*="[quantite]"]') || 
                                 div.querySelector('input.quantity-input') ||
                                 div.querySelector('input[type="number"]');
                
                if (qtyInput) {
                    // Trouver le conteneur parent du champ quantité
                    let fieldContainer = qtyInput.closest('.space-y-4') || qtyInput.parentElement;
                    
                    // Créer un wrapper pour le champ quantité avec position relative
                    const quantityWrapper = document.createElement('div');
                    quantityWrapper.className = 'relative';
                    quantityWrapper.style.width = '100%';
                    
                    // Déplacer l'input dans le wrapper
                    const qtyParent = qtyInput.parentElement;
                    qtyParent.insertBefore(quantityWrapper, qtyInput);
                    quantityWrapper.appendChild(qtyInput);
                    
                    // Ajouter le padding-right à l'input pour faire de la place aux boutons
                    qtyInput.style.paddingRight = '3rem';
                    qtyInput.classList.add('quantity-input');
                    
                    // Créer les boutons spinner
                    const spinnerContainer = document.createElement('div');
                    spinnerContainer.className = 'quantity-spinner-container';
                    spinnerContainer.style.cssText = 'position: absolute; top: 0; right: 0; bottom: 0; width: 3rem; display: flex; flex-direction: column; border-left: 1px solid #d1d5db; border-radius: 0 0.5rem 0.5rem 0; background: white; z-index: 10;';
                    
                    // Bouton increment (flèche vers le haut)
                    const incrementBtn = document.createElement('button');
                    incrementBtn.type = 'button';
                    incrementBtn.className = 'quantity-increment';
                    incrementBtn.style.cssText = 'flex: 1; display: flex; align-items: center; justify-content: center; color: #4b5563; cursor: pointer; border: none; outline: none; background: white; border-radius: 0 0.5rem 0 0; transition: background-color 0.2s;';
                    incrementBtn.setAttribute('aria-label', 'Augmenter');
                    incrementBtn.innerHTML = '<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>';
                    incrementBtn.addEventListener('mouseenter', function() { this.style.backgroundColor = '#f3f4f6'; });
                    incrementBtn.addEventListener('mouseleave', function() { this.style.backgroundColor = 'white'; });
                    
                    let incrementInterval = null;
                    const startIncrement = function() {
                        const step = parseInt(qtyInput.step) || 1;
                        const updateValue = function() {
                            const currentValue = parseInt(qtyInput.value) || 0;
                            qtyInput.value = currentValue + step;
                            qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
                            qtyInput.dispatchEvent(new Event('input', { bubbles: true }));
                        };
                        updateValue(); // Première incrémentation immédiate
                        incrementInterval = setInterval(updateValue, 100); // Répète toutes les 100ms
                    };
                    const stopIncrement = function() {
                        if (incrementInterval) {
                            clearInterval(incrementInterval);
                            incrementInterval = null;
                        }
                    };
                    incrementBtn.addEventListener('mousedown', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        startIncrement();
                    });
                    incrementBtn.addEventListener('mouseup', stopIncrement);
                    incrementBtn.addEventListener('mouseleave', stopIncrement);
                    incrementBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                    });
                    
                    // Bouton decrement (flèche vers le bas)
                    const decrementBtn = document.createElement('button');
                    decrementBtn.type = 'button';
                    decrementBtn.className = 'quantity-decrement';
                    decrementBtn.style.cssText = 'flex: 1; display: flex; align-items: center; justify-content: center; color: #4b5563; cursor: pointer; border: none; outline: none; background: white; border-radius: 0 0 0.5rem 0; transition: background-color 0.2s;';
                    decrementBtn.setAttribute('aria-label', 'Diminuer');
                    decrementBtn.innerHTML = '<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>';
                    decrementBtn.addEventListener('mouseenter', function() { this.style.backgroundColor = '#f3f4f6'; });
                    decrementBtn.addEventListener('mouseleave', function() { this.style.backgroundColor = 'white'; });
                    
                    let decrementInterval = null;
                    const startDecrement = function() {
                        const step = parseInt(qtyInput.step) || 1;
                        const min = parseInt(qtyInput.min) || 0;
                        const updateValue = function() {
                            const currentValue = parseInt(qtyInput.value) || 0;
                            const newValue = Math.max(min, currentValue - step);
                            qtyInput.value = newValue;
                            qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
                            qtyInput.dispatchEvent(new Event('input', { bubbles: true }));
                        };
                        updateValue(); // Première décrémentation immédiate
                        decrementInterval = setInterval(updateValue, 100); // Répète toutes les 100ms
                    };
                    const stopDecrement = function() {
                        if (decrementInterval) {
                            clearInterval(decrementInterval);
                            decrementInterval = null;
                        }
                    };
                    decrementBtn.addEventListener('mousedown', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        startDecrement();
                    });
                    decrementBtn.addEventListener('mouseup', stopDecrement);
                    decrementBtn.addEventListener('mouseleave', stopDecrement);
                    decrementBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                    });
                    
                    spinnerContainer.appendChild(incrementBtn);
                    spinnerContainer.appendChild(decrementBtn);
                    quantityWrapper.appendChild(spinnerContainer);
                }
                
                // Autocomplete
                const ingInput = div.querySelector('.ingredient-search-input');
                if (ingInput) {
                    const container = ingInput.parentElement;
                    if (!container.classList.contains('relative')) container.classList.add('relative');
                    const autocomplete = document.createElement('div');
                    autocomplete.className = 'ingredient-autocomplete absolute z-10 w-full bg-white border border-gray-300 rounded-lg shadow-lg mt-1 hidden max-h-60 overflow-y-auto';
                    container.appendChild(autocomplete);
                    if (window.initIngredientAutocomplete) window.initIngredientAutocomplete(ingInput);
                    
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.className = 'ingredient-id-hidden';
                    container.appendChild(hidden);
                    ingInput.addEventListener('change', function() {
                        hidden.value = this.dataset.ingredientId || '';
                    });
                }
                
                // Labels
                div.querySelectorAll('label').forEach(l => {
                    l.className = 'block text-sm font-semibold text-dark-blue mb-2';
                });
                
                // Select
                const select = div.querySelector('select');
                if (select) {
                    select.className = 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-green focus:border-transparent';
                }
                
                // Bouton supprimer
                const remove = document.createElement('button');
                remove.type = 'button';
                remove.className = 'mt-2 text-red-600 hover:text-red-800 text-sm font-semibold';
                remove.textContent = 'Supprimer';
                remove.onclick = () => div.remove();
                div.querySelector('.space-y-4').appendChild(remove);
                
                ingredientsList.appendChild(div);
                index++;
            }
            
            if (addBtn) addBtn.onclick = addIngredient;
            
            const form = document.getElementById('recipe-form');
            if (form) {
                form.onsubmit = function() {
                    ingredientsList.querySelectorAll('.ingredient-item').forEach(item => {
                        const qty = item.querySelector('input[type="number"]');
                        const unit = item.querySelector('select');
                        const hidden = item.querySelector('.ingredient-id-hidden');
                        if (qty && unit && hidden) {
                            const combined = unit.value ? `${qty.value} ${unit.value}`.trim() : qty.value;
                            const qtyField = item.querySelector('input[name*="[quantite]"]');
                            if (qtyField) qtyField.value = combined;
                            const idField = item.querySelector('input[name*="[ingredient_id]"]');
                            if (idField && hidden.value) idField.value = hidden.value;
                        }
                    });
                };
            }
        });
    </script>
{% endblock %}
