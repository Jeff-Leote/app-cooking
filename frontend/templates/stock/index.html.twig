{% extends 'layouts/app.html.twig' %}

{% block header %}
    {% embed 'components/header.html.twig' %}
        {% block page_title %}Stock{% endblock %}
        
        {% block page_subtitle %}
            <p class="text-sm text-gray-500 mt-1" id="stock-count">
                <span id="stock-count-number">0</span> ingrédient(s) en stock
            </p>
        {% endblock %}

        {% block header_actions %}
            <button 
                id="add-stock-item-btn"
                class="inline-flex items-center justify-center gap-2 bg-primary-green text-white font-semibold px-4 py-2 rounded-lg hover:bg-opacity-90 transition-all duration-200 shadow-sm hover:shadow-md"
            >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>Ajouter au stock</span>
            </button>
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block content %}
    <div class="space-y-6">
        {# Formulaire d'ajout (caché par défaut) #}
        <div id="add-stock-form" class="hidden bg-white rounded-xl shadow-sm p-6">
            <h2 class="text-xl font-bold text-dark-blue mb-4">Ajouter un ingrédient au stock</h2>
            <form id="new-stock-item-form" class="space-y-4">
                <div>
                    <label for="stock-ingredient" class="block text-sm font-semibold text-dark-blue mb-2">Ingrédient</label>
                    <select
                        id="stock-ingredient"
                        name="ingredient_id"
                        required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-green focus:border-transparent"
                    >
                        <option value="">Sélectionner un ingrédient...</option>
                        {# Les ingrédients seront chargés dynamiquement #}
                    </select>
                </div>
                <div>
                    <label for="stock-quantity" class="block text-sm font-semibold text-dark-blue mb-2">Quantité (optionnel)</label>
                    <input
                        type="text"
                        id="stock-quantity"
                        name="quantite"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-green focus:border-transparent"
                        placeholder="Ex: 1L, 500g, 3 pièces..."
                    >
                </div>
                <div>
                    <label for="stock-expiry" class="block text-sm font-semibold text-dark-blue mb-2">Date de péremption (optionnel)</label>
                    <input
                        type="date"
                        id="stock-expiry"
                        name="date_peremption"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-green focus:border-transparent"
                    >
                </div>
                <div class="flex gap-3">
                    <button
                        type="submit"
                        class="flex-1 bg-primary-green text-white font-semibold px-4 py-2 rounded-lg hover:bg-opacity-90 transition-all duration-200"
                    >
                        Ajouter
                    </button>
                    <button
                        type="button"
                        id="cancel-add-stock-btn"
                        class="flex-1 bg-gray-200 text-gray-700 font-semibold px-4 py-2 rounded-lg hover:bg-gray-300 transition-all duration-200"
                    >
                        Annuler
                    </button>
                </div>
            </form>
        </div>

        {# Liste du stock #}
        <div class="bg-white rounded-xl shadow-sm p-6">
            <h2 class="text-xl font-bold text-dark-blue mb-6">Ingrédients en stock</h2>
            <div id="stock-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                {# Les ingrédients seront chargés dynamiquement via JavaScript #}
            </div>
            <div id="stock-empty" class="hidden text-center py-12">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
                <p class="text-gray-500 text-lg font-semibold">Votre stock est vide</p>
                <p class="text-gray-400 text-sm mt-2">Ajoutez des ingrédients pour commencer à gérer votre stock</p>
            </div>
        </div>
    </div>
{% endblock %}
